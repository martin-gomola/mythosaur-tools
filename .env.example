# Core
# Bearer token for MCP auth. Generate one with: openssl rand -hex 32
MT_API_KEY=replace-with-strong-token
MT_MCP_PORT=8064
MT_PROFILE=readonly
# Optional default consumer profile when the client does not send X-Mythosaur-Consumer.
MT_DEFAULT_CONSUMER=codex
MT_RATE_LIMIT=120

# Workspace
# Host path mounted as /workspace in the container. MCP tools operate on this directory only.
# Standalone (Cursor/IDE): use . for this repo, or the absolute path of the project you work on.
# With mythosaur-ai: that repo overrides via WORKSPACE_DIR so both stacks share one workspace.
MT_WORKSPACE_HOST=/path/to/workspace
MT_WORKSPACE_ROOT=/workspace
# Base dir for PII repo scans and hook installs. Defaults to the workspace root when unset.
MT_PII_ROOT=/workspace
# Local CLI path written into installed pre-commit hooks. Leave empty to use scripts/pii_scan.py from this repo.
MT_PII_SCRIPT_PATH=

# Search
MT_SEARXNG_PORT=8063
MT_SEARXNG_URL=http://searxng-cache:8080
MT_SEARXNG_TOKEN=

# Browser
MT_BROWSER_ENABLED=true
MT_BROWSER_HEADLESS=true

# Google Workspace
MT_GOOGLE_CREDENTIALS_FILE=/secrets/google-credentials.json
MT_GOOGLE_TOKEN_FILE=/secrets/google-token.json
MT_GOOGLE_CALENDAR_READ_ENABLED=true
MT_GOOGLE_CALENDAR_WRITE_ENABLED=true
MT_GOOGLE_GMAIL_READ_ENABLED=true
MT_GOOGLE_GMAIL_SEND_ENABLED=true
MT_GOOGLE_DRIVE_READ_ENABLED=true
MT_GOOGLE_DRIVE_WRITE_ENABLED=true
MT_GOOGLE_SHEETS_READ_ENABLED=true
MT_GOOGLE_SHEETS_WRITE_ENABLED=true
MT_GOOGLE_DOCS_READ_ENABLED=true
MT_GOOGLE_DOCS_WRITE_ENABLED=true
MT_GOOGLE_PHOTOS_READ_ENABLED=true
MT_GOOGLE_PHOTOS_WRITE_ENABLED=true
MT_GOOGLE_MAPS_ENABLED=true
MT_GOOGLE_MAPS_NAVIGATE_DEFAULT=false
MT_GOOGLE_MAPS_API_KEY=
# Optional Google Maps Platform project identifier for future API-backed itinerary features.
MT_GOOGLE_MAPS_PLATFORM=

# NotebookLM
MT_NOTEBOOKLM_ENABLED=true
MT_NOTEBOOKLM_BIN=nlm
MT_NOTEBOOKLM_PROFILE=mythosaur
MT_NOTEBOOKLM_TIMEOUT=120
# Shared NotebookLM CLI state used by both the host login flow and the container runtime.
MT_NOTEBOOKLM_MCP_CLI_PATH=/secrets/notebooklm

# Logging
MT_LOG_LEVEL=INFO
MT_USAGE_LOG_EVERY=5
MT_USAGE_LOG_INTERVAL_SEC=60
