MYTHOSAUR_TOOLS_API_KEY=replace-with-strong-token
MYTHOSAUR_TOOLS_MCP_PORT=8064
MYTHOSAUR_TOOLS_PROFILE=readonly
# Host path mounted into the container workspace root.
MYTHOSAUR_TOOLS_WORKSPACE_HOST=../mythosaur-ai
MYTHOSAUR_TOOLS_WORKSPACE_ROOT=/workspace
# Base dir for PII repo scans and hook installs. Defaults to the workspace root when unset.
MYTHOSAUR_TOOLS_PII_ROOT=/workspace
# Local CLI path written into installed pre-commit hooks. Leave empty to use scripts/pii_scan.py from this repo.
MYTHOSAUR_TOOLS_PII_SCRIPT_PATH=
MYTHOSAUR_TOOLS_SEARXNG_PORT=8063
MYTHOSAUR_TOOLS_SEARXNG_URL=http://searxng-cache:8080
MYTHOSAUR_TOOLS_SEARXNG_TOKEN=
MYTHOSAUR_TOOLS_BROWSER_ENABLED=false
MYTHOSAUR_TOOLS_BROWSER_HEADLESS=true
MYTHOSAUR_TOOLS_GOOGLE_CREDENTIALS_FILE=/data/google-credentials.json
MYTHOSAUR_TOOLS_GOOGLE_TOKEN_FILE=/data/google-token.json
MYTHOSAUR_TOOLS_RATE_LIMIT=120
LOG_LEVEL=INFO
