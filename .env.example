# Core
MYTHOSAUR_TOOLS_API_KEY=replace-with-strong-token
MYTHOSAUR_TOOLS_MCP_PORT=8064
MYTHOSAUR_TOOLS_PROFILE=readonly
MYTHOSAUR_TOOLS_RATE_LIMIT=120

# Workspace
# Host path mounted into the container workspace root.
MYTHOSAUR_TOOLS_WORKSPACE_HOST=../mythosaur-ai
MYTHOSAUR_TOOLS_WORKSPACE_ROOT=/workspace
# Base dir for PII repo scans and hook installs. Defaults to the workspace root when unset.
MYTHOSAUR_TOOLS_PII_ROOT=/workspace
# Local CLI path written into installed pre-commit hooks. Leave empty to use scripts/pii_scan.py from this repo.
MYTHOSAUR_TOOLS_PII_SCRIPT_PATH=

# Search
MYTHOSAUR_TOOLS_SEARXNG_PORT=8063
MYTHOSAUR_TOOLS_SEARXNG_URL=http://searxng-cache:8080
MYTHOSAUR_TOOLS_SEARXNG_TOKEN=

# Browser
MYTHOSAUR_TOOLS_BROWSER_ENABLED=true
MYTHOSAUR_TOOLS_BROWSER_HEADLESS=true

# Google Workspace
MYTHOSAUR_TOOLS_GOOGLE_CREDENTIALS_FILE=/data/google-credentials.json
MYTHOSAUR_TOOLS_GOOGLE_TOKEN_FILE=/data/google-token.json
MYTHOSAUR_TOOLS_GOOGLE_CALENDAR_READ_ENABLED=true
MYTHOSAUR_TOOLS_GOOGLE_CALENDAR_WRITE_ENABLED=true
MYTHOSAUR_TOOLS_GOOGLE_GMAIL_READ_ENABLED=true
MYTHOSAUR_TOOLS_GOOGLE_GMAIL_SEND_ENABLED=true
MYTHOSAUR_TOOLS_GOOGLE_DRIVE_READ_ENABLED=true
MYTHOSAUR_TOOLS_GOOGLE_DRIVE_WRITE_ENABLED=true
MYTHOSAUR_TOOLS_GOOGLE_SHEETS_READ_ENABLED=true
MYTHOSAUR_TOOLS_GOOGLE_SHEETS_WRITE_ENABLED=true
MYTHOSAUR_TOOLS_GOOGLE_MAPS_ENABLED=true
MYTHOSAUR_TOOLS_GOOGLE_MAPS_NAVIGATE_DEFAULT=false

# NotebookLM
MYTHOSAUR_TOOLS_NOTEBOOKLM_ENABLED=true
MYTHOSAUR_TOOLS_NOTEBOOKLM_BIN=nlm
MYTHOSAUR_TOOLS_NOTEBOOKLM_PROFILE=mythosaur
MYTHOSAUR_TOOLS_NOTEBOOKLM_TIMEOUT=120
# Shared NotebookLM CLI state used by both the host login flow and the container runtime.
NOTEBOOKLM_MCP_CLI_PATH=/data/notebooklm

# Logging
LOG_LEVEL=INFO
